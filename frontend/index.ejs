<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>Guess The Country</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <div class="page">
      <header>
        <h1>Guess The Country</h1>
        <p class="subtitle">Get 3 clues and try to guess the country.</p>
      </header>

      <div class="card">
        <% if (!clues && typeof correct === 'undefined' && !error) { %>
          <!-- Landing state: only Start a Game button -->
          <div class="section">
            <form action="/game" method="get">
              <button type="submit">Start a Game</button>
            </form>
          </div>
        <% } %>

        <% if (clues) { %>
          <!-- Game state: show clues and guess form -->
          <div class="section">
            <div class="clues-title">Your clues:</div>
            <ul>
              <% clues.forEach(function (clue) { %>
                <li><%= clue %></li>
              <% }); %>
            </ul>
          </div>

          <div class="section">
            <form action="/game/validate" method="post">
              <input type="hidden" name="id" value="<%= countryId %>" />
              <label for="guess">Your guess:</label>
              <input
                type="text"
                id="guess"
                name="guess"
                placeholder="Type a country name"
                autocomplete="off"
              />
              <div class="actions">
                <button type="submit">Submit Guess</button>
              </div>
            </form>
          </div>
        <% } %>

        <% if (typeof correct !== 'undefined') { %>
          <!-- Result state: show correct/incorrect and options -->
          <div class="section">
            <div class="result">
              <% if (correct) { %>
                Correct!
              <% } else { %>
                wrong. The correct country was <strong><%= correctName %></strong>.
              <% } %>
            </div>
          </div>
          <div class="section">
            <div class="actions">
              <a href="/game" class="button-link">Start New Game</a>
            </div>
          </div>
        <% } %>

        <% if (error) { %>
          <!-- Error state -->
          <div class="section">
            <div class="error"><%= error %></div>
          </div>
          <div class="section">
            <div class="actions">
              <a href="/game" class="button-link">Start a Game</a>
            </div>
          </div>
        <% } %>
      </div>
    </div>
  </body>
</html>

